{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parley",
  "version": "0.1.0",
  "identifier": "ai.parley.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Parley",
        "width": 1120,
        "height": 780,
        "minWidth": 720,
        "minHeight": 520,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
